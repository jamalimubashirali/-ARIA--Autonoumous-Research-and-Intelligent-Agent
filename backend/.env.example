# ==== Azure AI Foundry (LLM) ====
AZURE_OPENAI_API_KEY="your_azure_ai_foundry_api_key"
AZURE_OPENAI_ENDPOINT="https://your-resource.services.ai.azure.com/models"
AZURE_OPENAI_API_DEPLOYMENT_MODEL_1="Llama-3.3-70B-Instruct"
AZURE_OPENAI_API_DEPLOYMENT_MODEL_2="Llama-4-Maverick-17B-128E-Instruct-FP8"

# ==== Embedding Model (Azure AI Foundry) ====
AZURE_EMBEDDING_ENDPOINT="https://your-resource.services.ai.azure.com/models"
AZURE_EMBEDDING_API_KEY="your_embedding_api_key"
AZURE_EMBEDDING_MODEL="Cohere-embed-v3-english"
EMBEDDING_DIMENSIONS=1024

# ==== Database (Supabase PostgreSQL via Pooler) ====
DB_HOST="aws-1-ap-south-1.pooler.supabase.com"
DB_PORT=5432
DB_NAME="postgres"
DB_USER="postgres.xvcqofbpfrcbulhorhwl"
DB_PASSWORD="your_supabase_db_password"

# ==== Web Search & Scraping ====
TAVILY_API_KEY="your_tavily_api_key"
FIRECRAWL_API_KEY="your_firecrawl_api_key"

# ==== Supabase ====
SUPABASE_URL="your_supabase_project_url"
SUPABASE_SERVICE_KEY="your_supabase_service_role_key"

# ==== Authentication (Clerk) ====
CLERK_SECRET_KEY="your_clerk_secret_key"
CLERK_JWKS_URL="https://clerk.yourdomain.com/.well-known/jwks.json"

# ==== Billing (Stripe) ====
STRIPE_SECRET_KEY="your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"

# ==== Observability (LangSmith) ====
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_API_KEY="your_langsmith_api_key"
LANGCHAIN_PROJECT="ARIA_Agent_Production"
